# =============================================================================
# OPENCODE STATISTICS
# =============================================================================

opencode_stats() {
  local db_path
  db_path=$(expand_path "~/.local/share/opencode/opencode.db")

  if [[ ! -f "$db_path" ]]; then
    printf "  "
    printf "${MUTED}%s${RESET}\n" "No data found"
    return 1
  fi

  # Query session statistics
  local total_sessions total_messages
  total_sessions=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM session;" 2>/dev/null || echo "0")
  total_messages=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM message;" 2>/dev/null || echo "0")

  # Query token statistics
  local total_input total_output total_reasoning total_cache_read total_cache_write total_cost
  total_input=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(tokens_input), 0) FROM session;" 2>/dev/null || echo "0")
  total_output=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(tokens_output), 0) FROM session;" 2>/dev/null || echo "0")
  total_reasoning=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(tokens_reasoning), 0) FROM session;" 2>/dev/null || echo "0")
  total_cache_read=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(tokens_cache_read), 0) FROM session;" 2>/dev/null || echo "0")
  total_cache_write=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(tokens_cache_write), 0) FROM session;" 2>/dev/null || echo "0")
  total_cost=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(cost), 0) FROM session;" 2>/dev/null || echo "0")

  local total_tokens=$((total_input + total_output + total_reasoning))

  # Output statistics
  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Sessions:")"
  printf " %s\n" "$(printc "$BOLD" "$(fmt_num "$total_sessions")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Messages:")"
  printf " %s\n" "$(printc "$BOLD" "$(fmt_num "$total_messages")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Input Tokens:")"
  printf " %s\n" "$(printc "$INFO" "$(fmt_num "$total_input")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Output Tokens:")"
  printf " %s\n" "$(printc "$INFO" "$(fmt_num "$total_output")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Reasoning Tokens:")"
  printf " %s\n" "$(printc "$WARNING" "$(fmt_num "$total_reasoning")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Cache Read:")"
  printf " %s\n" "$(printc "$SUCCESS" "$(fmt_num "$total_cache_read")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Cache Write:")"
  printf " %s\n" "$(printc "$SUCCESS" "$(fmt_num "$total_cache_write")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Total Tokens:")"
  printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$(fmt_num "$total_tokens")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Est. Cost:")"
  printf " %s\n" "$(printc "$DANGER" "\$$(printf "%.4f" "$total_cost")")"

  # Model breakdown
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Model Breakdown в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
  printf "  ${MUTED}%-30s %8s %15s${RESET}\n" "Model" "Sessions" "Tokens"
  sqlite3 "$db_path" "SELECT
        COALESCE(json_extract(model, '$.id'), model, 'unknown') as model_name,
        COUNT(*) as sessions,
        SUM(tokens_input + tokens_output + tokens_reasoning) as total_tokens
    FROM session
    WHERE model IS NOT NULL
    GROUP BY model
    ORDER BY total_tokens DESC;" 2>/dev/null | while IFS='|' read -r model sessions tokens; do
    printf "  ${INFO}%-30s${RESET} ${MUTED}%8s${RESET} ${HIGHLIGHT}%15s${RESET} ${MUTED}tokens${RESET}\n" \
      "$model" "$sessions" "$(fmt_num "$tokens")"
  done

  return 0
}

