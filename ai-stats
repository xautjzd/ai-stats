      done
    fi
  else
    printf "  ${MUTED}%s${RESET}\n" "No config found at ~/.config/opencode/opencode.json"
  fi
}

# Daily activity for OpenCode
opencode_daily() {
  local db_path
  db_path=$(expand_path "~/.local/share/opencode/opencode.db")

  if [[ ! -f "$db_path" ]]; then
    return 1
  fi

  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Recent 7 Days в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
  printf "  ${MUTED}%-12s %10s %15s %12s${RESET}\n" "Date" "Sessions" "Tokens" "Cost"
  sqlite3 "$db_path" "SELECT
        date(time_created/1000, 'unixepoch', 'localtime') as day,
        COUNT(*) as sessions,
        SUM(tokens_input + tokens_output + tokens_reasoning) as tokens,
        SUM(cost) as cost
    FROM session
    WHERE time_created > (strftime('%s', 'now') - 7*24*60*60) * 1000
    GROUP BY day
    ORDER BY day DESC;" 2>/dev/null | while IFS='|' read -r day sessions tokens cost; do
    printf "  ${INFO}%-12s${RESET} ${BOLD}%10s${RESET} %15s ${DANGER}%12s${RESET}\n" \
      "$day" "$sessions" "$(fmt_num "$tokens")" "\$$(printf "%.4f" "${cost:-0}")"
  done
}

