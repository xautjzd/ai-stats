# CODEX CLI STATISTICS
# =============================================================================

codex_stats() {
  local db_path
  db_path=$(expand_path "~/.codex/state_5.sqlite")

  if [[ ! -f "$db_path" ]]; then
    printf "  "
    printf "${MUTED}%s${RESET}\n" "No data found"
    return 1
  fi

  # Query thread statistics
  local total_threads active_threads archived_threads
  total_threads=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM threads;" 2>/dev/null || echo "0")
  active_threads=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM threads WHERE archived = 0;" 2>/dev/null || echo "0")
  archived_threads=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM threads WHERE archived = 1;" 2>/dev/null || echo "0")

  # Query token statistics
  local total_tokens
  total_tokens=$(sqlite3 "$db_path" "SELECT COALESCE(SUM(tokens_used), 0) FROM threads;" 2>/dev/null || echo "0")

  # Query source and provider breakdown
  local cli_count vscode_count
  cli_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM threads WHERE source = 'cli';" 2>/dev/null || echo "0")
  vscode_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM threads WHERE source = 'vscode';" 2>/dev/null || echo "0")

  # Output statistics
  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Total Threads:")"
  printf " %s\n" "$(printc "$BOLD" "$(fmt_num "$total_threads")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Active Threads:")"
  printf " %s\n" "$(printc "$SUCCESS" "$(fmt_num "$active_threads")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Archived Threads:")"
  printf " %s\n" "$(printc "$MUTED" "$(fmt_num "$archived_threads")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Total Tokens Used:")"
  printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$(fmt_num "$total_tokens")")"

  # Source breakdown
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Source Breakdown в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
  printf "  "
  printf "%-20s" "$(printc "$MUTED" "CLI:")"
  printf " %s\n" "$(printc "$INFO" "$(fmt_num "$cli_count")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "VS Code:")"
  printf " %s\n" "$(printc "$INFO" "$(fmt_num "$vscode_count")")"

  # Model breakdown
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Model Breakdown в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
  printf "  ${MUTED}%-30s %8s %15s${RESET}\n" "Model" "Sessions" "Tokens"
  sqlite3 "$db_path" "SELECT
        COALESCE(model, 'unknown') as model_name,
        COUNT(*) as sessions,
        SUM(tokens_used) as total_tokens
    FROM threads
    WHERE model IS NOT NULL
    GROUP BY model
    ORDER BY total_tokens DESC;" 2>/dev/null | while IFS='|' read -r model sessions tokens; do
    printf "  ${INFO}%-30s${RESET} ${MUTED}%8s${RESET} ${HIGHLIGHT}%15s${RESET} ${MUTED}tokens${RESET}\n" \
      "$model" "$sessions" "$(fmt_num "$tokens")"
  done

  return 0
}

codex_extensions() {
  local config="$HOME/.codex/config.toml"
  local plugins_dir="$HOME/.codex/.tmp/plugins/plugins"

  # Skills (enabled plugins)
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Skills в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"

  if [[ -f "$config" ]]; then
    local enabled_plugins
    enabled_plugins=$(awk '/^\[plugins\./ { gsub(/^\[plugins\."/, ""); gsub(/"\].*/, ""); plugin=$0 } /^enabled = true/ { print plugin }' "$config" 2>/dev/null)
    local plugin_count
    plugin_count=$(echo "$enabled_plugins" | grep -c . 2>/dev/null || echo "0")

    printf "  "
    printf "%-20s" "$(printc "$MUTED" "Enabled:")"
    printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$plugin_count")"
    echo "$enabled_plugins" | grep . | while read -r plugin; do
      printf "  ${MUTED}  вЂў${RESET} ${INFO}%s${RESET}\n" "$plugin"
    done
  else
    printf "  ${MUTED}%s${RESET}\n" "No config found at ~/.codex/config.toml"
    return
  fi

  # MCP Servers (from enabled plugins' .mcp.json)
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ MCP Servers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"

  if [[ ! -d "$plugins_dir" ]]; then
    printf "  ${MUTED}%s${RESET}\n" "No plugins directory found"
    return
  fi

  local enabled_plugins
  enabled_plugins=$(awk '/^\[plugins\./ { gsub(/^\[plugins\."/, ""); gsub(/"\].*/, ""); plugin=$0 } /^enabled = true/ { print plugin }' "$config" 2>/dev/null)

  echo "$enabled_plugins" | grep . | while read -r plugin_id; do
    local plugin_dir_name="${plugin_id%%@*}"
    local mcp_file="$plugins_dir/$plugin_dir_name/.mcp.json"
    [[ ! -f "$mcp_file" ]] && continue
    local count
    count=$(jq -r '.mcpServers | length' "$mcp_file" 2>/dev/null || echo "0")
    [[ "$count" -eq 0 ]] && continue
    printf "  ${MUTED}  вЂў${RESET} ${INFO}%-30s${RESET} ${HIGHLIGHT}%3s${RESET} ${MUTED}server(s)${RESET}\n" "$plugin_dir_name" "$count"
  done

  local mcp_total=0
  while IFS= read -r plugin_id; do
    [[ -z "$plugin_id" ]] && continue
    local plugin_dir_name="${plugin_id%%@*}"
    local mcp_file="$plugins_dir/$plugin_dir_name/.mcp.json"
    [[ ! -f "$mcp_file" ]] && continue
    local c
    c=$(jq -r '.mcpServers | length' "$mcp_file" 2>/dev/null || echo "0")
    mcp_total=$((mcp_total + c))
  done <<<"$enabled_plugins"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Configured:")"
  printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$mcp_total")"
}

