#!/usr/bin/env bash
#
# AI Coding Tools Usage Statistics
# Supports: Claude Code, OpenCode, Codex CLI
# Extensible architecture for adding new tools
#
# Compatible with Bash 3.x+ (macOS default)
#

set -e

# =============================================================================
# CONFIGURATION
# =============================================================================

# Terminal dimensions for responsive design
TERM_WIDTH=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
TERM_HEIGHT=${LINES:-$(tput lines 2>/dev/null || echo 24)}

# Colors and formatting
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
ITALIC='\033[3m'
UNDERLINE='\033[4m'

# Theme colors вЂ” semantic roles, not decorative
PRIMARY='\033[38;5;68m'    # Steel blue вЂ” structural chrome, borders
SECONDARY='\033[38;5;147m' # Soft purple вЂ” section / subsection labels
SUCCESS='\033[38;5;78m'    # Sage green вЂ” cache hits, efficiency
WARNING='\033[38;5;208m'   # Amber вЂ” caution
DANGER='\033[38;5;167m'    # Dusty rose вЂ” cost figures
INFO='\033[38;5;74m'       # Cornflower вЂ” token counts
MUTED='\033[38;5;240m'     # Charcoal вЂ” de-emphasized labels
HIGHLIGHT='\033[38;5;229m' # Pale gold вЂ” totals & key figures

# Per-tool brand colors вЂ” intentionally distinct from semantic palette
COLOR_CLAUDE='\033[38;5;135m'  # Orchid    вЂ” Claude / Anthropic
COLOR_OPENCODE='\033[38;5;44m' # Turquoise вЂ” OpenCode
COLOR_CODEX='\033[38;5;221m'   # Gold      вЂ” Codex CLI

# Tool registry (using regular arrays instead of associative)
TOOL_NAMES=("claude" "opencode" "codex")
TOOL_DISPLAYS=("Claude Code" "OpenCode" "Codex CLI")
TOOL_PATHS=("~/.claude/stats-cache.json" "~/.local/share/opencode/opencode.db" "~/.codex/state_5.sqlite")
TOOL_TYPES=("json" "sqlite" "sqlite")

# =============================================================================
# UTILITY FUNCTIONS
# =============================================================================

# Print colored text (no newline)
printc() {
  local color="$1"
  local text="$2"
  printf "${color}%s${RESET}" "$text"
}

# Print colored text with newline
printcln() {
  local color="$1"
  local text="$2"
  printf "${color}%s${RESET}\n" "$text"
}

# Print horizontal line
hr() {
  local char="${1:-в”Ђ}"
  local width=${2:-$TERM_WIDTH}
  printf '%*s\n' "$width" '' | tr ' ' "$char"
}

# Print section header
section() {
  local title="$1"
  local width=${2:-$TERM_WIDTH}
  printf "\n"
  printf "${PRIMARY}%s${RESET}\n" "$(hr 'в”Ђ' "$width")"
  printf "${SECONDARY}${BOLD}  в–Є %s${RESET}\n" "$title"
  printf "${PRIMARY}%s${RESET}\n" "$(hr 'в”Ђ' "$width")"
}

# Print full-width tool banner with distinct color
# Usage: tool_banner "TOOL NAME" "icon" "$COLOR"
tool_banner() {
  local title="$1"
  local icon="$2"
  local color="$3"
  local width=${TERM_WIDTH:-80}
  printf "\n"
  printf "${color}%s${RESET}\n" "$(hr 'в”Ѓ' "$width")"
  printf "${color}${BOLD}  %s  %s${RESET}\n" "$icon" "$title"
  printf "${color}%s${RESET}\n" "$(hr 'в”Ѓ' "$width")"
  printf "\n"
}

# Print full-width separator between tool sections
tool_separator() {
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "$(hr 'в•Њ')"
  printf "\n"
}

# Print subsection header
subsection() {
  printf "\n${SECONDARY}  в”Њв”Ђ %s${RESET}\n" "$1"
}

# Render a fixed-width ASCII progress bar
progress_bar() {
  local value="$1"
  local max="$2"
  local width="${3:-20}"
  local color="${4:-$PRIMARY}"
  if [[ -z "$max" || "$max" -eq 0 ]]; then
    printf "${MUTED}%s${RESET}" "$(printf '%*s' "$width" '' | tr ' ' 'в–‘')"
    return
  fi
  local filled=$((value * width / max))
  [[ $filled -gt $width ]] && filled=$width
  local empty=$((width - filled))
  [[ $filled -gt 0 ]] && printf "${color}%s${RESET}" "$(printf '%*s' "$filled" '' | tr ' ' 'в–€')"
  [[ $empty -gt 0 ]] && printf "${MUTED}%s${RESET}" "$(printf '%*s' "$empty" '' | tr ' ' 'в–‘')"
}

# Format large numbers with commas
fmt_num() {
  local num="$1"
  if [[ "$num" == "null" || -z "$num" ]]; then
    echo "0"
  elif command -v numfmt &>/dev/null; then
    echo "$num" | numfmt --grouping 2>/dev/null || echo "$num"
  else
    # Manual comma insertion for systems without numfmt
    printf "%'d\n" "$num" 2>/dev/null || echo "$num"
  fi
}

# Format bytes to human readable
fmt_bytes() {
  local bytes="$1"
  if [[ -z "$bytes" || "$bytes" == "0" ]]; then
    echo "0 B"
  elif command -v numfmt &>/dev/null; then
    numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || echo "$bytes B"
  else
    if ((bytes > 1073741824)); then
      printf "%.2f GB" "$((bytes / 1073741824)).$((bytes % 1073741824 / 10000000))"
    elif ((bytes > 1048576)); then
      printf "%.2f MB" "$((bytes / 1048576)).$((bytes % 1048576 / 10000))"
    elif ((bytes > 1024)); then
      printf "%.2f KB" "$((bytes / 1024)).$((bytes % 1024 / 10))"
    else
      echo "$bytes B"
    fi
  fi
}

# Format milliseconds to duration
fmt_duration() {
  local ms="$1"
  if [[ -z "$ms" || "$ms" == "0" ]]; then
    echo "0s"
    return
  fi

  local seconds=$((ms / 1000))
  local minutes=$((seconds / 60))
  local hours=$((minutes / 60))
  local days=$((hours / 24))

  if ((days > 0)); then
    printf "%dd %dh %dm" "$days" $((hours % 24)) $((minutes % 60))
  elif ((hours > 0)); then
    printf "%dh %dm %ds" "$hours" $((minutes % 60)) $((seconds % 60))
  elif ((minutes > 0)); then
    printf "%dm %ds" "$minutes" $((seconds % 60))
  else
    printf "%ds" "$seconds"
  fi
}

# Expand tilde in paths
expand_path() {
  local path="$1"
  if [[ "${path:0:1}" == "~" ]]; then
    echo "$HOME${path:1}"
  else
    echo "$path"
  fi
}

# Check if tool data exists
tool_exists() {
  local path="$1"
  local full_path
  full_path=$(expand_path "$path")
  [[ -f "$full_path" ]]
}

# =============================================================================
# CLAUDE CODE STATISTICS
# =============================================================================

claude_stats() {
  local path
  path=$(expand_path "~/.claude/stats-cache.json")

  if [[ ! -f "$path" ]]; then
    printf "  "
    printf "${MUTED}%s${RESET}\n" "No data found"
    return 1
  fi

  local data
  data=$(cat "$path")

  # Extract key metrics
  local total_sessions total_messages
  total_sessions=$(echo "$data" | jq -r '.totalSessions // 0' 2>/dev/null || echo "0")
  total_messages=$(echo "$data" | jq -r '.totalMessages // 0' 2>/dev/null || echo "0")

  # Calculate total tokens from modelUsage
  local total_input total_output total_cache_read total_cache_write
  total_input=$(echo "$data" | jq -r '[.modelUsage[]?.inputTokens // 0] | add' 2>/dev/null || echo "0")
  total_output=$(echo "$data" | jq -r '[.modelUsage[]?.outputTokens // 0] | add' 2>/dev/null || echo "0")
  total_cache_read=$(echo "$data" | jq -r '[.modelUsage[]?.cacheReadInputTokens // 0] | add' 2>/dev/null || echo "0")
  total_cache_write=$(echo "$data" | jq -r '[.modelUsage[]?.cacheCreationInputTokens // 0] | add' 2>/dev/null || echo "0")

  local total_tokens=$((total_input + total_output))

  # Output statistics
  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Sessions:")"
  printf " %s\n" "$(printc "$BOLD" "$(fmt_num "$total_sessions")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Messages:")"
  printf " %s\n" "$(printc "$BOLD" "$(fmt_num "$total_messages")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Input Tokens:")"
  printf " %s\n" "$(printc "$INFO" "$(fmt_num "$total_input")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Output Tokens:")"
  printf " %s\n" "$(printc "$INFO" "$(fmt_num "$total_output")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Cache Read:")"
  printf " %s\n" "$(printc "$SUCCESS" "$(fmt_num "$total_cache_read")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Cache Write:")"
  printf " %s\n" "$(printc "$SUCCESS" "$(fmt_num "$total_cache_write")")"

  printf "  "
  printf "%-20s" "$(printc "$MUTED" "Total Tokens:")"
  printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$(fmt_num "$total_tokens")")"

  # Model breakdown
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Model Breakdown в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
  printf "  ${MUTED}%-30s %15s${RESET}\n" "Model" "Tokens"
  echo "$data" | jq -r '.modelUsage | to_entries | sort_by(.value.inputTokens + .value.outputTokens) | reverse | .[] |
        "\(.key)\t\(.value.inputTokens + .value.outputTokens)"' 2>/dev/null | while IFS=$'\t' read -r model tokens; do
    printf "  ${INFO}%-30s${RESET} ${HIGHLIGHT}%15s${RESET} ${MUTED}tokens${RESET}\n" "$model" "$(fmt_num "$tokens")"
  done

  return 0
}

# MCP servers and skills stats for Claude Code
claude_extensions() {
  # MCP servers from desktop config
  local mcp_config="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
  local mcp_count=0

  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ MCP Servers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"

  if [[ -f "$mcp_config" ]] && command -v jq &>/dev/null; then
    mcp_count=$(jq -r '.mcpServers | length' "$mcp_config" 2>/dev/null || echo "0")
    printf "  "
    printf "%-20s" "$(printc "$MUTED" "Configured:")"
    printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$mcp_count")"
    jq -r '.mcpServers | keys | .[]' "$mcp_config" 2>/dev/null | while read -r name; do
      printf "  ${MUTED}  вЂў${RESET} ${INFO}%s${RESET}\n" "$name"
    done
  else
    printf "  ${MUTED}%s${RESET}\n" "No MCP config found"
  fi

  # Skills from installed plugins
  printf "\n"
  printf "${MUTED}%s${RESET}\n" "  в”Ђв”Ђ Skills в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"

  local plugins_file="$HOME/.claude/plugins/installed_plugins.json"
  local total_skills=0

  if [[ -f "$plugins_file" ]] && command -v jq &>/dev/null; then
    # Collect unique install paths
    local install_paths
    install_paths=$(jq -r '.plugins | to_entries[] | .value[] | .installPath' "$plugins_file" 2>/dev/null | sort -u)

    local plugin_names
    plugin_names=$(jq -r '.plugins | keys | .[]' "$plugins_file" 2>/dev/null)

    printf "  "
    printf "%-20s" "$(printc "$MUTED" "Installed Plugins:")"
    printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$(echo "$plugin_names" | wc -l | tr -d ' ')")"

    while IFS= read -r install_path; do
      [[ -z "$install_path" ]] && continue
      local count=0
      # Prefer skills/*/SKILL.md (modern system), fallback to .claude/commands/*.md
      if [[ -d "$install_path/skills" ]]; then
        count=$(find "$install_path/skills" -name "SKILL.md" | wc -l | tr -d ' ')
      elif [[ -d "$install_path/.claude/commands" ]]; then
        count=$(find "$install_path/.claude/commands" -name "*.md" | wc -l | tr -d ' ')
      fi
      [[ "$count" -eq 0 ]] && continue
      total_skills=$((total_skills + count))
      # Derive plugin display name from path
      local plugin_name
      plugin_name=$(echo "$install_path" | sed 's|.*/cache/[^/]*/||' | sed 's|/[^/]*$||')
      printf "  ${MUTED}  вЂў${RESET} ${INFO}%-30s${RESET} ${HIGHLIGHT}%3s${RESET} ${MUTED}skills${RESET}\n" "$plugin_name" "$count"
    done <<<"$install_paths"

    printf "  "
    printf "%-20s" "$(printc "$MUTED" "Total Skills:")"
    printf " %s\n" "$(printc "$HIGHLIGHT$BOLD" "$total_skills")"
  else
    printf "  ${MUTED}%s${RESET}\n" "No plugin data found"
  fi
}

