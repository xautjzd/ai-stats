# =============================================================================
# MAIN
# =============================================================================

main() {
  local command="${1:-dashboard}"
  local output_file=""

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -o | --output)
      output_file="$2"
      shift 2
      ;;
    --no-color)
      # Disable colors
      RESET=''
      BOLD=''
      DIM=''
      PRIMARY=''
      SECONDARY=''
      SUCCESS=''
      WARNING=''
      DANGER=''
      INFO=''
      MUTED=''
      HIGHLIGHT=''
      shift
      ;;
    --width)
      TERM_WIDTH="$2"
      shift 2
      ;;
    -h | --help | help | h)
      show_help
      exit 0
      ;;
    *)
      command="$1"
      shift
      ;;
    esac
  done

  # Check dependencies
  if ! command -v sqlite3 &>/dev/null; then
    echo "Error: sqlite3 is required but not installed." >&2
    exit 1
  fi

  # Execute command
  case "$command" in
  dashboard | d | "" | all)
    show_dashboard
    show_claude
    show_opencode
    show_codex
    ;;
  claude | c)
    show_claude
    ;;
  opencode | o)
    show_opencode
    ;;
  codex | x)
    show_codex
    ;;
  compare | cmp)
    show_comparison
    ;;
  export | e)
    export_json "$output_file"
    ;;
  *)
    echo "Unknown command: $command"
    show_help
    exit 1
    ;;
  esac
}

main "$@"
