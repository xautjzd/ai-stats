export_json() {
  local output_file="${1:-ai-stats-$(date +%Y%m%d-%H%M%S).json}"
  local json="{"
  json="${json}\"generated_at\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\","
  json="${json}\"tools\":{"

  local first=true

  # Claude Code
  if tool_exists "~/.claude/stats-cache.json"; then
    [[ "$first" == false ]] && json="${json},"
    first=false
    local data
    data=$(cat "$(expand_path "~/.claude/stats-cache.json")")
    json="${json}\"claude_code\":$data"
  fi

  # OpenCode
  if tool_exists "~/.local/share/opencode/opencode.db"; then
    [[ "$first" == false ]] && json="${json},"
    first=false
    local db
    db=$(expand_path "~/.local/share/opencode/opencode.db")
    json="${json}\"opencode\":{"
    json="${json}\"sessions\":$(sqlite3 "$db" "SELECT COUNT(*) FROM session;" 2>/dev/null || echo "0"),"
    json="${json}\"messages\":$(sqlite3 "$db" "SELECT COUNT(*) FROM message;" 2>/dev/null || echo "0"),"
    json="${json}\"tokens_input\":$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_input), 0) FROM session;" 2>/dev/null || echo "0"),"
    json="${json}\"tokens_output\":$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_output), 0) FROM session;" 2>/dev/null || echo "0"),"
    json="${json}\"tokens_reasoning\":$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_reasoning), 0) FROM session;" 2>/dev/null || echo "0"),"
    json="${json}\"tokens_cache_read\":$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_cache_read), 0) FROM session;" 2>/dev/null || echo "0"),"
    json="${json}\"tokens_cache_write\":$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_cache_write), 0) FROM session;" 2>/dev/null || echo "0"),"
    json="${json}\"total_cost\":$(sqlite3 "$db" "SELECT COALESCE(SUM(cost), 0) FROM session;" 2>/dev/null || echo "0")"
    json="${json}}"
  fi

  # Codex CLI
  if tool_exists "~/.codex/state_5.sqlite"; then
    [[ "$first" == false ]] && json="${json},"
    first=false
    local db
    db=$(expand_path "~/.codex/state_5.sqlite")
    json="${json}\"codex\":{"
    json="${json}\"threads\":$(sqlite3 "$db" "SELECT COUNT(*) FROM threads;" 2>/dev/null || echo "0"),"
    json="${json}\"active_threads\":$(sqlite3 "$db" "SELECT COUNT(*) FROM threads WHERE archived = 0;" 2>/dev/null || echo "0"),"
    json="${json}\"archived_threads\":$(sqlite3 "$db" "SELECT COUNT(*) FROM threads WHERE archived = 1;" 2>/dev/null || echo "0"),"
    json="${json}\"tokens_used\":$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_used), 0) FROM threads;" 2>/dev/null || echo "0")"
    json="${json}}"
  fi

  json="${json}}}"

  if command -v jq &>/dev/null; then
    echo "$json" | jq '.' >"$output_file"
  else
    echo "$json" >"$output_file"
  fi
  printf "${SUCCESS}%s${RESET}\n" "Exported to: $output_file"
}

