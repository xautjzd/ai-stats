  # Summary cards
  local claude_sessions=0 opencode_sessions=0 codex_sessions=0
  local claude_tokens=0 opencode_tokens=0 codex_tokens=0
  local has_data=false

  # Collect data
  if tool_exists "~/.claude/stats-cache.json"; then
    local data
    data=$(cat "$(expand_path "~/.claude/stats-cache.json")")
    claude_sessions=$(echo "$data" | jq -r '.totalSessions // 0' 2>/dev/null || echo "0")
    local claude_input claude_output
    claude_input=$(echo "$data" | jq -r '[.modelUsage[]?.inputTokens // 0] | add' 2>/dev/null || echo "0")
    claude_output=$(echo "$data" | jq -r '[.modelUsage[]?.outputTokens // 0] | add' 2>/dev/null || echo "0")
    claude_tokens=$((claude_input + claude_output))
    has_data=true
  fi

  if tool_exists "~/.local/share/opencode/opencode.db"; then
    local db
    db=$(expand_path "~/.local/share/opencode/opencode.db")
    opencode_sessions=$(sqlite3 "$db" "SELECT COUNT(*) FROM session;" 2>/dev/null || echo "0")
    opencode_tokens=$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_input + tokens_output + tokens_reasoning), 0) FROM session;" 2>/dev/null || echo "0")
    has_data=true
  fi

  if tool_exists "~/.codex/state_5.sqlite"; then
    local db
    db=$(expand_path "~/.codex/state_5.sqlite")
    codex_sessions=$(sqlite3 "$db" "SELECT COUNT(*) FROM threads;" 2>/dev/null || echo "0")
    codex_tokens=$(sqlite3 "$db" "SELECT COALESCE(SUM(tokens_used), 0) FROM threads;" 2>/dev/null || echo "0")
    has_data=true
  fi

  if [[ "$has_data" == false ]]; then
    printc "$WARNING" "No data found for any supported tools."
    return 1
  fi

  local total_sessions=$((claude_sessions + opencode_sessions + codex_sessions))
  local total_tokens=$((claude_tokens + opencode_tokens + codex_tokens))

  # Summary section
  printf "${SECONDARY}${BOLD}%s${RESET}\n" "рџ“Љ OVERVIEW"
  printf "\n"
  printf "  ${MUTED}%-20s${RESET} " "Total Sessions:"
  printf "${HIGHLIGHT}${BOLD}%s${RESET}\n" "$(fmt_num "$total_sessions")"
  printf "  ${MUTED}%-20s${RESET} " "Total Tokens:"
  printf "${HIGHLIGHT}${BOLD}%s${RESET}\n" "$(fmt_num "$total_tokens")"
  printf "\n"

  # Tool breakdown
  printf "${SECONDARY}${BOLD}%s${RESET}\n" "рџ”§ TOOL BREAKDOWN"
  printf "\n"
  printf "  ${MUTED}%-15s %10s %20s  %-20s %5s${RESET}\n" "Tool" "Sessions" "Tokens" "" "Share"
  printf "  ${MUTED}%s${RESET}\n" "$(hr 'в”Ђ' 74)"

  local max_tokens=$((total_tokens > 0 ? total_tokens : 1))

  if [[ "$claude_sessions" -gt 0 ]]; then
    local pct=$((claude_tokens * 100 / max_tokens))
    printf "  ${COLOR_CLAUDE}${BOLD}в—† %-13s${RESET} %10s %20s  " "Claude Code" "$(fmt_num "$claude_sessions")" "$(fmt_num "$claude_tokens")"
    progress_bar "$claude_tokens" "$total_tokens" 20 "$COLOR_CLAUDE"
    printf " ${MUTED}%3d%%${RESET}\n" "$pct"
  fi
  if [[ "$opencode_sessions" -gt 0 ]]; then
    local pct=$((opencode_tokens * 100 / max_tokens))
    printf "  ${COLOR_OPENCODE}${BOLD}в—€ %-13s${RESET} %10s %20s  " "OpenCode" "$(fmt_num "$opencode_sessions")" "$(fmt_num "$opencode_tokens")"
    progress_bar "$opencode_tokens" "$total_tokens" 20 "$COLOR_OPENCODE"
    printf " ${MUTED}%3d%%${RESET}\n" "$pct"
  fi
  if [[ "$codex_sessions" -gt 0 ]]; then
    local pct=$((codex_tokens * 100 / max_tokens))
    printf "  ${COLOR_CODEX}${BOLD}в—‡ %-13s${RESET} %10s %20s  " "Codex CLI" "$(fmt_num "$codex_sessions")" "$(fmt_num "$codex_tokens")"
    progress_bar "$codex_tokens" "$total_tokens" 20 "$COLOR_CODEX"
    printf " ${MUTED}%3d%%${RESET}\n" "$pct"
  fi

  printf "\n"
  printf "${PRIMARY}%s${RESET}\n" "$(hr 'в”Ѓ')"
